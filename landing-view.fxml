<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.geometry.Insets?>
        <?import javafx.scene.control.Button?>
        <?import javafx.scene.control.Label?>
        <?import javafx.scene.layout.AnchorPane?>
        <?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.prodjects_gui.LandingController"
            prefHeight="600.0"
            prefWidth="900.0"
            style="-fx-background-color: linear-gradient(to bottom, #dff6dd, #b8e6b8);">

    <children>

        <VBox alignment="CENTER"
              spacing="20"
              AnchorPane.topAnchor="50.0"
              AnchorPane.bottomAnchor="50.0"
              AnchorPane.leftAnchor="200.0"
              AnchorPane.rightAnchor="200.0">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Learning Management System"
                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>

            <Label text="Welcome to the LMS"
                   style="-fx-font-size: 18px; -fx-text-fill: #555555;"/>

            <Button text="Student Dashboard"
                    prefWidth="250"
                    prefHeight="40"
                    onAction="#openStudentDashboard"/>

            <Button text="Course Management"
                    prefWidth="250"
                    prefHeight="40"
                    onAction="#openCourseManagement"/>

            <Button text="Assignment Submission"
                    prefWidth="250"
                    prefHeight="40"
                    onAction="#openAssignmentSubmission"/>

            <Button text="Quiz Page"
                    prefWidth="250"
                    prefHeight="40"
                    onAction="#openQuizPage"/>

            <Button text="View Grades"
                    prefWidth="250"
                    prefHeight="40"
                    onAction="#openViewGrades"/>

            <Label fx:id="statusLabel"
                   text="Select an option to continue."
                   style="-fx-font-size: 14px; -fx-text-fill: #00695C;"/>

        </VBox>

    </children>

</AnchorPane>

